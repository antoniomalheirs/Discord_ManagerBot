# ========================================
# Discord Bot — Variáveis de Ambiente
# ========================================
# Copie este arquivo para .env e preencha:
#   cp .env.example .env
# ========================================

# === Discord ===
TOKEN=SEU_TOKEN_DO_DISCORD_AQUI
CLIENT_ID=SEU_CLIENT_ID_AQUI
GUILD_ID=SEU_GUILD_ID_AQUI

# === MongoDB ===
# Use MongoDB Atlas (cloud) — Recomendado para Termux
# Crie uma conta grátis em: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://usuario:senha@cluster.xxxxx.mongodb.net/discordbot?retryWrites=true&w=majority

# === YouTube Data API v3 ===
# Gere em: https://console.cloud.google.com/apis/credentials
YOUTUBE_API=SUA_CHAVE_DE_API_DO_YOUTUBE_AQUI

# === Twitch API ===
# Registre em: https://dev.twitch.tv/console/apps
TWITCH_CLIENTID=SEU_CLIENT_ID_DA_TWITCH_AQUI
TWITCH_SECRETID=SEU_CLIENT_SECRET_DA_TWITCH_AQUI
